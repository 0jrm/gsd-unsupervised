    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "simple-git": "^3.27.0",
    "tree-kill": "^1.2.2",
    "twilio": "^5.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "supertest": "^7.2.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
