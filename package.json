{
  "name": "gsd-unsupervised",
  "version": "1.0.3",
  "description": "Autonomous orchestrator for Cursor agent + GSD framework",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "gsd-unsupervised": "bin/gsd-unsupervised"
  },
  "files": [
    "dist",
    "bin",
    ".gsd-framework"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0jrm/gsd-unsupervised.git"
  },
  "keywords": [
    "cursor",
